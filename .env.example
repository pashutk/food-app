# food-app MCP Server — environment variables
# Copy this file to .env and fill in your values

# Base URL of the food-app backend (no trailing slash)
API_BASE_URL=http://localhost:3000

# Credentials for the food-app (used by the MCP server to auto-login)
AUTH_EMAIL=your-username
AUTH_PASSWORD=your-password

# --- food-app backend variables (for running the app itself) ---
JWT_SECRET=your-jwt-secret
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-password
DB_PATH=./data/food.db
PORT=3000
