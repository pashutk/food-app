# food-app environment variables
# Copy this file to .env and fill in your values

# --- food-app backend ---
PORT=3000
DB_PATH=./data/food.db
JWT_SECRET=change-me-to-a-long-random-string
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# --- MCP server ---
# When running locally, point to the backend directly
# When running via docker-compose, use http://app:3000 instead
API_BASE_URL=http://localhost:3000
# AUTH_EMAIL should match AUTH_USERNAME above
AUTH_EMAIL=admin
# AUTH_PASSWORD is shared with the backend above
